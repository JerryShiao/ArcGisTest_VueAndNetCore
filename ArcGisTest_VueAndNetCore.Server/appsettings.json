{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  //=== TDX運輸資料流通服務平臺 API 金鑰 ===
  "TdxApi": {
    "ClientId": "",    //TDX API Client ID
    "ClientSecret": "" // TDX API Client Secret
  },

  //=== 航遙測圖資 API 配置 ===
  "AsrsGovApi": {
    "ConnectAccount": "", // 連線帳號
    "ConnectPassword": "", // 認證密碼
    "AerialPhotographyWmsUrl": "/ASO2015/wms", // 航照-全臺正射影像(WMS) 服務的 URL
    "UavWmsUrl": "/uav/wms", // 無人機鑲嵌正射影像(WMS) 服務的 URL
    "Fs2WmsUrl": "/FS2/wms", // 福衛二號影像(WMS) 服務的 URL
    "Fs2WmsLayerName": "FS2:fs2015-1_masked_2m_enhance", // 福衛二號影像(WMS) 服務的 圖層名稱
    "Fs2WmtsUrl": "/gwc/service/wmts", // 福衛二號影像(WMTS) 服務的 URL
    "Fs2WmtsLayerName": "FS2:fs2015-1_masked_2m_enhance" // 福衛二號影像(WMTS) 服務的 圖層名稱
  },

  //=== YARP 網域配置 ===
  "ReverseProxy": {
    "Routes": {
      // === 路由 1：對應到 asrs 網域 ===
      "asrs-route": {
        "ClusterId": "asrs-cluster", // 指定交給下面哪一個伺服器集群處理
        "Match": {
          "Path": "/api-asrs/{**catchall}" // 前端呼叫路徑
        },
        "Transforms": [
          { "PathRemovePrefix": "/api-asrs" } // 轉發時移除前綴
        ]
      },

      // === 路由 2：對應到 fs2 網域 ===
      "fs2-route": {
        "ClusterId": "fs2-cluster", // 指定交給下面哪一個伺服器集群處理
        "Match": {
          "Path": "/api-fs2/{**catchall}" // 前端呼叫路徑
        },
        "Transforms": [
          { "PathRemovePrefix": "/api-fs2" } // 轉發時移除前綴
        ]
      },

      // === 路由 3：對應到 ltgis 網域（時價登錄房價 ImageServer）===
      "ltgis-route": {
        "ClusterId": "ltgis-cluster",
        "Match": {
          "Path": "/api-ltgis/{**catchall}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api-ltgis" }
        ]
      }
    },

    "Clusters": {
      // === 集群 1：asrs 伺服器設定 ===
      "asrs-cluster": {
        "Destinations": {
          "destination1": {
            // 基礎網域到 /asofb/ 即可，後面路徑由前端帶入
            "Address": "https://wmstest.asrs.gov.tw/asofb/"
          }
        }
      },

      // === 集群 2：fs2 伺服器設定 ===
      "fs2-cluster": {
        "Destinations": {
          "destination1": {
            // 基礎網域到 /asofb/ 即可，後面路徑由前端帶入
            "Address": "https://wmstest.asrs.gov.tw/asofb/"
          }
        }
      },

      // === 集群 3：ltgis 伺服器設定（時價登錄房價 ImageServer）===
      "ltgis-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://ltgis.info/"
          }
        }
      }
    }
  }
}
